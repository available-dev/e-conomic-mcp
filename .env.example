# e-conomic REST API credentials (direct token auth)
# Both tokens are sent on every request as HTTP headers:
#   X-AppSecretToken:       ECONOMIC_APP_SECRET_TOKEN
#   X-AgreementGrantToken:  ECONOMIC_AGREEMENT_GRANT_TOKEN
#
# How to obtain them:
#   - App secret token:  from your app registration in the e-conomic developer portal.
#   - Agreement grant token: issued when an e-conomic agreement (company) grants your app access.
#   For local/demo experimentation e-conomic publishes demo tokens in their docs.
ECONOMIC_APP_SECRET_TOKEN=
ECONOMIC_AGREEMENT_GRANT_TOKEN=

# --- Optional ---

# Override the REST API base URL (default: https://restapi.e-conomic.com)
# ECONOMIC_BASE_URL=https://restapi.e-conomic.com

# Path or URL to an OpenAPI/Swagger spec. When set, the discovery tools use it
# and (if enabled) per-endpoint tools are generated from it.
# Examples:
#   ECONOMIC_OPENAPI_SPEC=./spec/economic-openapi.json
#   ECONOMIC_OPENAPI_SPEC=https://apis.e-conomic.com/...swagger.json
# ECONOMIC_OPENAPI_SPEC=

# Directory of e-conomic's native per-endpoint JSON Schema files
# (e.g. vat-zones.vatZoneNumber.get.schema.json). Used as an alternative to
# ECONOMIC_OPENAPI_SPEC for discovery and dynamic tool generation. Populate it
# with scripts/crawl-schemas.mjs.
# ECONOMIC_SCHEMA_DIR=./spec/schemas

# Generate one MCP tool per operation (requires ECONOMIC_OPENAPI_SPEC or
# ECONOMIC_SCHEMA_DIR).
# Off by default because large APIs can exceed client tool limits.
# ECONOMIC_DYNAMIC_TOOLS=true

# Cap the number of dynamically generated tools (default: 200)
# ECONOMIC_DYNAMIC_TOOLS_LIMIT=200

# Default page size for paginated collection reads (default: 100, max 1000)
# ECONOMIC_PAGE_SIZE=100

# Request timeout in milliseconds (default: 30000)
# ECONOMIC_TIMEOUT_MS=30000
