{
	"$schema": "http://json-schema.org/draft-03/schema#",
	"title": "Company PUT schema",
	"description": "A schema for updating company information under self.",
	"type": "object",
	"restdocs": "http://restdocs.e-conomic.com/#put-self-company",
	"properties": {
		"addressLine1": {
			"type": "string",
			"description": "The company's address.",
			"required": true
		},
		"addressLine2": {
			"type": "string",
			"description": "The company's address."
		},
		"zip": {
			"type": "string",
			"description": "The company's postcode.",
			"required": true
		},
		"city": {
			"type": "string",
			"description": "The company's city.",
			"required": true
		},
		"name": {
			"type": "string",
			"description": "The company's name.",
			"required": true
		},
		"country": {
			"type": "string",
			"description": "The company's country."
		},
		"phoneNumber": {
			"type": "string",
			"description": "The company's phone number.",
			"required": true
		},
		"attention": {
			"type": "string",
			"description": "The company's primary contact person.",
			"required": true
		},
		"website": {
			"type": "string",
			"description": "The company's web site url."
		},
		"email": {
			"type": "string",
			"description": "The company's email.",
			"required": true
		},
		"companyIdentificationNumber": {
			"type": "string",
			"description": "The company's identification number. For example CVR in Denmark."
		},
		"vatNumber": {
			"type": "string",
			"description": "The company's value added tax identification number. This field is only available to agreements in Sweden. Not to be mistaken for the danish CVR number, which is defined on the 'companyIdentificationNumber' property."
		}
	}
}